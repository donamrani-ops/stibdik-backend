# ═══════════════════════════════════════════════════════════
#  STIBDIK BACKEND - VARIABLES D'ENVIRONNEMENT
# ═══════════════════════════════════════════════════════════

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/stibdik
# Pour MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/stibdik?retryWrites=true&w=majority

# JWT Secret Keys
JWT_SECRET=votre_secret_jwt_super_securise_changez_moi_en_production
JWT_REFRESH_SECRET=votre_refresh_secret_super_securise
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Cloudinary (Upload images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CMI Payment Gateway (Morocco)
CMI_MERCHANT_ID=your_merchant_id
CMI_SECRET_KEY=your_cmi_secret_key
CMI_GATEWAY_URL=https://payment.cmi.co.ma/
CMI_OK_URL=http://localhost:3000/payment/success
CMI_FAIL_URL=http://localhost:3000/payment/failure

# Email Configuration (SendGrid, Mailgun, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@stibdik.ma

# SMS Configuration (Twilio, etc.)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+212XXXXXXXXX

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Admin Configuration
ADMIN_EMAIL=admin@stibdik.ma
ADMIN_PASSWORD=changeme_secure_password

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_SMS_VERIFICATION=false
ENABLE_EMAIL_VERIFICATION=true

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log
